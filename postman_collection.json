{
  "info": {
    "name": "Order Management System",
    "description": "Complete API collection for the Order Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3001/api" },
    { "key": "secretKey", "value": "oms-super-secret-scheduler-key-2024" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orders",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"John Doe\",\n  \"phone\": \"+91-9876543210\",\n  \"productName\": \"Wireless Keyboard\",\n  \"amount\": 1299.00,\n  \"paymentStatus\": \"PAID\"\n}"
            }
          }
        },
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders?page=1&limit=10&sortBy=createdAt&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sortBy", "value": "createdAt" },
                { "key": "sortOrder", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "Filter Orders by Status",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders?status=PLACED",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [{ "key": "status", "value": "PLACED" }]
            }
          }
        },
        {
          "name": "Search Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders?search=John",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [{ "key": "search", "value": "John" }]
            }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Update Order",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/orders/{{orderId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentStatus\": \"PAID\",\n  \"status\": \"PROCESSING\"\n}"
            }
          }
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "Scheduler",
      "item": [
        {
          "name": "Trigger Scheduler (Manual)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/scheduler/run",
            "header": [{ "key": "x-secret-key", "value": "{{secretKey}}" }]
          }
        },
        {
          "name": "Get Scheduler Logs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/scheduler/logs?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["scheduler", "logs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "header": [{ "key": "x-secret-key", "value": "{{secretKey}}" }]
          }
        }
      ]
    }
  ]
}
